# Fluvius Energy API credentials — copy to .env and fill in your own values.
# Never commit .env (already in .gitignore).

# Common — required
FLUVIUS_SUBSCRIPTION_KEY=your-azure-apim-subscription-key
FLUVIUS_TENANT_ID=your-azure-ad-tenant-id
FLUVIUS_SCOPE=api://your-scope-guid/.default
FLUVIUS_DATA_ACCESS_CONTRACT_NUMBER=your-contract-number

# Production (certificate auth)
FLUVIUS_CLIENT_ID=your-prod-client-id
FLUVIUS_CERTIFICATE_THUMBPRINT=your-certificate-thumbprint
# Preferred: point to a PEM file with chmod 600 rather than base64 in an env var
FLUVIUS_PRIVATE_KEY_PATH=/path/to/private_key.pem
# Alternative: base64-encoded PEM (less safe — appears in process env)
# FLUVIUS_PRIVATE_KEY=base64-encoded-pem-contents

# Sandbox (client secret auth)
FLUVIUS_SANDBOX_CLIENT_ID=your-sandbox-client-id
FLUVIUS_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret